[Unit]
Description=CUP public TCP forwarding proxy
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/bin/python3 /home/softcup/to_public/tcp_proxy.py --map 0.0.0.0:20080=127.0.0.1:18001
Restart=always
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=default.target
