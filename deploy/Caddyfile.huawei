{
    admin off
    auto_https off
}

:20443 {
    tls /home/softcup/to_public/tls/server.crt /home/softcup/to_public/tls/server.key
    reverse_proxy 127.0.0.1:18001

    log {
        output stdout
        format console
    }
}

:20444 {
    tls /home/softcup/to_public/tls/server.crt /home/softcup/to_public/tls/server.key
    reverse_proxy 127.0.0.1:18011 {
        header_up Host 127.0.0.1:8011
    }

    log {
        output stdout
        format console
    }
}
