[Unit]
Description=Titan reverse tunnel from AutoDL to Huawei edge
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/bin/ssh -NT -i /root/.ssh/cup_titan_huawei_ed25519 -o BatchMode=yes -o ExitOnForwardFailure=yes -o ServerAliveInterval=15 -o ServerAliveCountMax=3 -o StrictHostKeyChecking=yes -R 127.0.0.1:20101:127.0.0.1:8001 -R 127.0.0.1:20111:127.0.0.1:8011 softcup@139.159.150.134
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
