# Copy to deploy/public.env, replace every CHANGE_ME value, then chmod 600.
PUBLIC_APP_URL=https://guide.example.com
PUBLIC_ADMIN_URL=https://admin.example.com

ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME
# Generate with: openssl rand -hex 32
ADMIN_SESSION_SECRET=CHANGE_ME

# Cloudflare Realtime TURN key and its API token.
CLOUDFLARE_TURN_KEY_ID=CHANGE_ME
CLOUDFLARE_TURN_API_TOKEN=CHANGE_ME
CLOUDFLARE_TURN_TTL_SECONDS=3600

# Token shown by a remotely-managed Cloudflare Tunnel.
CLOUDFLARE_TUNNEL_TOKEN=CHANGE_ME

# The campus NAT cannot expose this host's coturn directly.
LOCAL_TURN_ENABLED=false
TURN_ENABLED=false

# Local BGE-M3 + FAISS + GLM RAG service (not exposed publicly).
RAG_URL=http://127.0.0.1:8020
RAG_PORT=8020
RAG_GPU=3
RAG_HF_OFFLINE=true
RAG_LLM_MODEL=glm-4-flash-250414
RAG_LLM_FALLBACK_MODELS=glm-4-flash
RAG_LLM_FIRST_TOKEN_TIMEOUT_SECONDS=2
RAG_EMBED_DEVICE=on-demand
RAG_EMBED_GPU_CANDIDATES=0,1,2,3
RAG_EMBED_GPU_MIN_FREE_MB=2048
RAG_EMBED_GPU_IDLE_SECONDS=180
RAG_SESSION_TTL_SECONDS=3600
RAG_SESSION_MAX_TURNS=6
RAG_WATCHDOG_INTERVAL_SECONDS=5
RAG_WATCHDOG_FAILURE_THRESHOLD=3

# Optional local chat route. Start on first use so GPU selection reflects the
# current load. Set LOCAL_LLM_GPU to a physical index only for manual override.
LOCAL_LLM_AUTOSTART=false
LOCAL_LLM_GPU=auto
LOCAL_LLM_GPU_CANDIDATES=0,1,2,3
LOCAL_LLM_GPU_MIN_FREE_MB=18000
LOCAL_LLM_PORT=8021
LOCAL_LLM_IDLE_SECONDS=120
RAG_LOCAL_LLM_BASE_URL=http://127.0.0.1:8021/v1
RAG_LOCAL_LLM_MODEL=/home/huggingface/Qwen2-7B-Instruct

# Lightweight local fallback for machines that cannot reserve enough VRAM for
# the full 7B route. It has its own port/process/log and also starts on demand.
LOCAL_LITE_LLM_AUTOSTART=false
LOCAL_LITE_LLM_GPU=auto
LOCAL_LITE_LLM_GPU_CANDIDATES=0,1,2,3
LOCAL_LITE_LLM_GPU_MIN_FREE_MB=6000
LOCAL_LITE_LLM_PORT=8022
LOCAL_LITE_LLM_IDLE_SECONDS=120
RAG_LOCAL_LITE_LLM_BASE_URL=http://127.0.0.1:8022/v1
RAG_LOCAL_LITE_LLM_MODEL=/home/datasets/EMO_GEN/EMO_GEN_model/Qwen/Qwen3-1.7B

# LiveTalking stays in CPU/RAM and selects a free GPU for active WebRTC sessions.
LIVETALKING_GPU=2
LIVETALKING_IDLE_SECONDS=120
LIVETALKING_CPU_STANDBY=true
LIVETALKING_GPU_CANDIDATES=0,1,2,3
LIVETALKING_GPU_MIN_FREE_MB=2048
LIVETALKING_GPU_OFFLOAD_DELAY_SECONDS=180
LIVETALKING_SESSION_LEASE_SECONDS=45
LIVETALKING_EXIT_AFTER_GPU_OFFLOAD=true
LIVETALKING_WATCHDOG_INTERVAL_SECONDS=1

# Visitor-dialogue emotion analysis. EMOTION_PYTHON must be able to import
# the training-time HumanOmni fork (including emotion_probs_from_logits),
# peft and torch.
EMOTION_MODEL_PATH=/home/gmn/codes/cup/model/emotion_v5_stage2
EMOTION_BASE_MODEL_PATH=/home/gmn/codes/cup/model/emotion_stage1
EMOTION_BERT_PATH=/home/huggingface/bert-base-uncased
EMOTION_INFERENCE_SCRIPT=/home/gmn/codes/cup/services/emotion/inference_adapter.py
EMOTION_PYTHON=/home/gmn/.conda/envs/softcup/bin/python
EMOTION_GPU=2
EMOTION_KEEP_MEDIA=false
