# Copy to deploy/public.env, replace every CHANGE_ME value, then chmod 600.
PUBLIC_APP_URL=https://guide.example.com
PUBLIC_ADMIN_URL=https://admin.example.com

ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME
# Generate with: openssl rand -hex 32
ADMIN_SESSION_SECRET=CHANGE_ME

# Cloudflare Realtime TURN key and its API token.
CLOUDFLARE_TURN_KEY_ID=CHANGE_ME
CLOUDFLARE_TURN_API_TOKEN=CHANGE_ME
CLOUDFLARE_TURN_TTL_SECONDS=3600

# Token shown by a remotely-managed Cloudflare Tunnel.
CLOUDFLARE_TUNNEL_TOKEN=CHANGE_ME

# The campus NAT cannot expose this host's coturn directly.
LOCAL_TURN_ENABLED=false
TURN_ENABLED=false

# Local BGE-M3 + FAISS + GLM RAG service (not exposed publicly).
RAG_URL=http://127.0.0.1:8020
RAG_PORT=8020
RAG_GPU=3
RAG_HF_OFFLINE=true
RAG_LLM_MODEL=glm-4.7-flash
RAG_EMBED_DEVICE=cuda:0
RAG_SESSION_TTL_SECONDS=3600
RAG_SESSION_MAX_TURNS=6
RAG_WATCHDOG_INTERVAL_SECONDS=5

# Optional local chat route. The server itself uses no model VRAM until selected.
LOCAL_LLM_AUTOSTART=true
LOCAL_LLM_GPU=2
LOCAL_LLM_PORT=8021
LOCAL_LLM_IDLE_SECONDS=120
RAG_LOCAL_LLM_BASE_URL=http://127.0.0.1:8021/v1
RAG_LOCAL_LLM_MODEL=/home/huggingface/Qwen2-7B-Instruct

# LiveTalking starts on the first visitor interaction, then stops when idle.
LIVETALKING_GPU=2
LIVETALKING_IDLE_SECONDS=120
